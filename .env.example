# Telegram API credentials (https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# Choose provider: lastfm or spotify
SOURCE=lastfm

# General behavior
POLL_INTERVAL_SEC=30
CLEAR_WHEN_NOT_PLAYING=true
#BIO_PREFIX=
#BIO_SUFFIX=
#BIO_SEPARATOR=
MAX_BIO_LENGTH=70

# Last.fm settings (required for SOURCE=lastfm)
LASTFM_API_KEY=
LASTFM_USERNAME=

# Spotify settings (required for SOURCE=spotify)
# You can either provide a ready access token (short-lived)...
SPOTIFY_ACCESS_TOKEN=
# ...or auto-refresh token flow values:
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
